# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ---- dependencies ----
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ---- builds / cache ----
/.next/
/out/
/build
/dist
/.turbo
*.tsbuildinfo
next-env.d.ts

# ---- testing ----
/coverage

# ---- env files (nunca subir secretos; opt-in si hiciera falta) ----
.env
.env.*
!.env.example

# ---- logs ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---- deploy ----
.vercel

# ---- editores / IDE ----
.idea/
*.swp
*.swo
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# ---- herramientas de agentes (config local, no compartir) ----
.claude/settings.local.json

# ---- sistema operativo ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
Desktop.ini

# ---- misc ----
*.pem

# ---- material interno (no publicar) ----
PROMO.md
MEJORAS.md
